import kagglehub
import pandas as pd
import os
import glob

# Baixa dataset
path = kagglehub.dataset_download(
    "fronkongames/steam-games-dataset"
)

print("Pasta:", path)

# Procura todos os CSVs dentro da pasta
arquivos_csv = glob.glob(
    os.path.join(path, "*.csv")
)

print("\nArquivos encontrados:")
for a in arquivos_csv:
    print(a)

if not arquivos_csv:
    raise Exception(
        "Nenhum CSV encontrado."
    )

# Pega o primeiro CSV encontrado
arquivo = arquivos_csv[0]

print("\nUsando:")
print(arquivo)

# Carrega
df = pd.read_csv(
    arquivo
)

print("\nInformações:")
print(df.info())

print("\nPrimeiras linhas:")
print(df.head())

# Salva cópia local organizada
df.to_csv(
    "steam_dataset.csv",
    index=False,
    encoding="utf-8"
)

print(
    "\nArquivo salvo:"
)
print(
    "steam_dataset.csv"
)